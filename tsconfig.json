{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": true
  },
  "include": ["scripts/**/*.mjs"],
  "exclude": ["node_modules", "apps/**", "tracebud-backend/**", "legacy/**", "packages/**"]
}
