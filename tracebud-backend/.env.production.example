# Copy values into Railway (or VPS) — never commit real secrets.

NODE_ENV=production
PORT=4001
HOST=0.0.0.0

# Supabase pooler URL (Session mode / port 5432 or transaction pooler 6543 per your setup)
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_key

# Optional: comma-separated extra browser origins (Vercel preview URLs, etc.)
# TRACEBUD_CORS_ORIGINS=https://your-dashboard.vercel.app

# Dashboard links in transactional email (if using Resend)
# TRACEBUD_DASHBOARD_PUBLIC_URL=https://dashboard.tracebud.com
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=hello@tracebud.com
# RESEND_FROM_NAME=Tracebud
# RESEND_REPLY_TO_EMAIL=hello@tracebud.com

# Onboarding welcome + resume nudges (cron: POST /api/v1/launch/onboarding/remind-incomplete)
# SUPABASE_SERVICE_ROLE_KEY=   # magic links for dropout resume emails
# LAUNCH_ONBOARDING_CRON_TOKEN=
# TRACEBUD_ONBOARDING_UNSUBSCRIBE_URL=https://dashboard.tracebud.com/settings

# Global Forest Watch — deforestation screening (REQUIRED for plot GFW checks)
GFW_API_KEY=your_gfw_api_key
GFW_BASE_URL=https://data-api.globalforestwatch.org
GFW_DATASET=gfw_integrated_alerts
GFW_VERSION=latest
GFW_RADD_DATASET=umd_glad_dist_alerts
# Post-EUDR-cutoff alert queries (support {{cutoffDate}} token):
GFW_DEFORESTATION_SQL_TEMPLATE=SELECT COUNT(*) AS count, SUM(area__ha) AS area_ha FROM data WHERE gfw_integrated_alerts__date > '{{cutoffDate}}'
GFW_FALLBACK_DEFORESTATION_SQL_TEMPLATE=SELECT COUNT(*) AS count, SUM(area__ha) AS area_ha FROM data WHERE umd_glad_landsat_alerts__date > '{{cutoffDate}}'

# Tenure document AI parse (Phase 1 producer-in-possession)
# Recommended: Vercel AI Gateway with per-request Zero Data Retention + no prompt training.
# Create key: Vercel dashboard → Project → AI Gateway → API keys
# Optional team-wide ZDR: AI Gateway → Settings → Zero Data Retention (Pro/Enterprise)
# AI_GATEWAY_API_KEY=your_vercel_ai_gateway_key
# AI_GATEWAY_URL=https://ai-gateway.vercel.sh/v1/chat/completions
# AI_TENURE_PARSE_MODEL=google/gemini-2.5-flash
# AI_TENURE_PARSE_ZDR=true
# VERCEL_OIDC_TOKEN=   # alternative auth on Vercel after `vercel env pull`
EVIDENCE_STORAGE_BUCKET=plot-evidence
# SUPABASE_SERVICE_ROLE_KEY=   # required to download tenure files from plot-evidence bucket
#
# Legacy fallback only (weaker privacy guarantees than gateway ZDR):
# OPENAI_API_KEY=

# Integrations / admin (set before enabling those features in prod)
# COOLFARM_SAI_V2_SCHEDULER_TOKEN=
# BENCHMARK_ADMIN_ROLE_CLAIMS=ADMIN,COMPLIANCE_MANAGER

# Month-end billing (cron: POST /api/v1/billing/invoices/finalize-period-cron)
# BILLING_SCHEDULER_TOKEN=
# STRIPE_SECRET_KEY=   # optional; creates Stripe invoices when tenant has stripe_customer_id
