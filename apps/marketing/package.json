{
  "name": "tracebud-marketing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint --config ../../packages/eslint-config/nextjs.mjs . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "i18n:parity:assert": "node scripts/i18n-parity-assert.mjs",
    "routes:publication:assert": "node scripts/marketing-routes-publication-guard.mjs",
    "api:trace:size:assert": "node scripts/marketing-api-trace-size-guard.mjs",
    "analytics:slice:assert": "node scripts/marketing-analytics-slice-guard.mjs",
    "analytics:slice:write-baseline": "node scripts/marketing-analytics-slice-guard.mjs --write-baseline",
    "insights:lint:assert": "node scripts/marketing-insights-lint-guard.mjs",
    "png:size:assert": "node scripts/marketing-png-size-guard.mjs --strict",
    "png:size:write-baseline": "node scripts/marketing-png-size-guard.mjs --write-baseline",
    "smoke:post-deploy": "node scripts/marketing-post-deploy-smoke.mjs",
    "e2e:golden-paths": "playwright test e2e/golden-paths.spec.ts",
    "e2e:golden-paths:assert": "node scripts/marketing-playwright-guard.mjs",
    "e2e:golden-paths:install": "playwright install chromium",
    "e2e:preview": "node scripts/run-marketing-preview-playwright.mjs",
    "e2e:preview:assert": "node scripts/marketing-playwright-preview-guard.mjs",
    "a11y:routes": "playwright test e2e/accessibility.spec.ts",
    "a11y:routes:assert": "node scripts/marketing-a11y-routes-guard.mjs",
    "a11y:routes:baseline:refresh": "A11Y_BASELINE_REFRESH=1 playwright test e2e/accessibility.spec.ts",
    "lighthouse:budgets": "node scripts/run-marketing-lighthouse-budgets.mjs",
    "lighthouse:budgets:assert": "node scripts/marketing-lighthouse-budget-guard.mjs",
    "check": "npm run lint && npm run typecheck && npm run i18n:parity:assert && npm run routes:publication:assert && npm run analytics:slice:assert && npm run insights:lint:assert && npm run png:size:assert && npm run e2e:golden-paths:assert && npm run build && npm run api:trace:size:assert",
    "sentry:env:assert": "node ../../scripts/sentry-env-tags-guard.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-aspect-ratio": "1.1.8",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-context-menu": "2.2.16",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-hover-card": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-menubar": "1.1.16",
    "@radix-ui/react-navigation-menu": "1.2.14",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-radio-group": "1.3.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-toast": "1.2.15",
    "@radix-ui/react-toggle": "1.1.10",
    "@radix-ui/react-toggle-group": "1.1.11",
    "@radix-ui/react-tooltip": "1.2.8",
    "@sentry/nextjs": "^10.57.0",
    "@supabase/supabase-js": "^2.100.0",
    "@vercel/analytics": "1.6.1",
    "@vercel/speed-insights": "^2.0.0",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.1.0",
    "embla-carousel-react": "8.6.0",
    "framer-motion": "^12.35.2",
    "input-otp": "1.4.2",
    "lucide-react": "^0.564.0",
    "next": "16.1.6",
    "next-intl": "^4.12.0",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-day-picker": "9.13.2",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.54.1",
    "react-resizable-panels": "^2.1.7",
    "recharts": "2.15.0",
    "resend": "^6.12.4",
    "sonner": "^1.7.1",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.51.1",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^22",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "axe-core": "^4.11.4",
    "lighthouse": "^13.4.0",
    "postcss": "^8.5",
    "shadcn": "^4.0.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "1.3.3",
    "typescript": "5.7.3"
  }
}
