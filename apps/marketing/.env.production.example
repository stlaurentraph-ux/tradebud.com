# Vercel production environment (Project Settings → Environment Variables)
# Public URL: https://tracebud.com

# Observability (create Sentry project: tracebud / marketing)
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_ENABLED=1
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
SENTRY_AUTH_TOKEN=your_sentry_org_auth_token
SENTRY_ORG=tracebud
SENTRY_PROJECT=marketing

# Forms / waitlist (Supabase + Resend)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# RESEND_API_KEY=
