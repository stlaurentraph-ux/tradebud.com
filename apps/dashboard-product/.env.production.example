# Vercel production environment (Project Settings → Environment Variables)
# Public URL: https://dashboard.tracebud.com (Domains → dashboard.tracebud.com)
TRACEBUD_BACKEND_URL=https://api.tracebud.com/api
NEXT_PUBLIC_SUPABASE_URL=https://uzsktajlnofosxeqwdwl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Observability (create Sentry project: tracebud / dashboard)
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_ENABLED=1
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
SENTRY_AUTH_TOKEN=your_sentry_org_auth_token
SENTRY_ORG=tracebud
SENTRY_PROJECT=dashboard

# Internal Founder OS / legacy CRM routes — off in production (set true for Tracebud staff only)
NEXT_PUBLIC_ENABLE_INTERNAL_TOOLS=false
