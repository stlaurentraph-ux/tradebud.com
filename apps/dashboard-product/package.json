{
  "name": "dashboard-product",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --config ../../packages/eslint-config/nextjs.mjs . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "regression:routes:assert": "node scripts/dashboard-regression-guard.mjs",
    "regression:routes:baseline:refresh": "node scripts/dashboard-regression-guard.mjs --write-baseline",
    "check": "npm run lint && npm run typecheck && npm run test && npm run regression:routes:assert",
    "i18n:build-overlays": "node scripts/build-dashboard-locale-overlays.mjs",
    "i18n:expand-workflow-overlays": "node scripts/expand-workflow-overlays.mjs",
    "qa:launch:onboarding:smoke": "node scripts/launch-onboarding-proxy-smoke.mjs",
    "deploy:smoke": "node scripts/run-dashboard-onboarding-smoke.mjs",
    "deploy:smoke:assert": "node scripts/dashboard-onboarding-smoke-guard.mjs",
    "openapi:codegen": "node scripts/generate-openapi-proxy-types.mjs",
    "openapi:codegen:assert": "node scripts/dashboard-openapi-codegen-guard.mjs",
    "proxy:contracts:assert": "node scripts/dashboard-proxy-contract-guard.mjs",
    "mock:prod:assert": "node scripts/dashboard-mock-vs-real-guard.mjs",
    "e2e:golden-paths": "playwright test",
    "e2e:golden-paths:assert": "node scripts/dashboard-playwright-guard.mjs",
    "e2e:golden-paths:install": "playwright install chromium",
    "analytics:slice:assert": "node ./scripts/dashboard-analytics-slice-guard.mjs --strict",
    "analytics:slice:write-baseline": "node ./scripts/dashboard-analytics-slice-guard.mjs --write-baseline",
    "qa:structural": "node ./scripts/run-structural-guards.mjs",
    "qa:structural:ci": "node ./scripts/run-structural-guards.mjs --ci"
  },
  "dependencies": {
    "@tracebud/import-v1-canonical": "*",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-accordion": "1.2.15",
    "@radix-ui/react-alert-dialog": "1.1.18",
    "@radix-ui/react-aspect-ratio": "1.1.11",
    "@radix-ui/react-avatar": "1.2.1",
    "@radix-ui/react-checkbox": "1.3.6",
    "@radix-ui/react-collapsible": "1.1.15",
    "@radix-ui/react-context-menu": "2.3.2",
    "@radix-ui/react-dialog": "1.1.18",
    "@radix-ui/react-dropdown-menu": "2.1.19",
    "@radix-ui/react-hover-card": "1.1.18",
    "@radix-ui/react-label": "2.1.11",
    "@radix-ui/react-menubar": "1.1.19",
    "@radix-ui/react-navigation-menu": "1.2.17",
    "@radix-ui/react-popover": "1.1.18",
    "@radix-ui/react-progress": "1.1.11",
    "@radix-ui/react-radio-group": "1.4.2",
    "@radix-ui/react-scroll-area": "1.2.13",
    "@radix-ui/react-select": "2.3.2",
    "@radix-ui/react-separator": "1.1.11",
    "@radix-ui/react-slider": "1.4.2",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-switch": "1.3.2",
    "@radix-ui/react-tabs": "1.1.16",
    "@radix-ui/react-toast": "1.2.18",
    "@radix-ui/react-toggle": "1.1.13",
    "@radix-ui/react-toggle-group": "1.1.14",
    "@radix-ui/react-tooltip": "1.2.11",
    "@sentry/nextjs": "^10.63.0",
    "@supabase/supabase-js": "^2.110.0",
    "@vercel/analytics": "2.0.1",
    "autoprefixer": "^10.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.4.0",
    "embla-carousel-react": "8.6.0",
    "fflate": "^0.8.3",
    "input-otp": "1.4.2",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-day-picker": "10.0.1",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.80.0",
    "react-resizable-panels": "^4.12.0",
    "sonner": "^2.0.7",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@tailwindcss/postcss": "^4.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "jsdom": "^27.0.1",
    "openapi-typescript": "^7.8.0",
    "postcss": "^8.5",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "1.3.3",
    "typescript": "5.7.3",
    "vitest": "^3.2.4"
  }
}
