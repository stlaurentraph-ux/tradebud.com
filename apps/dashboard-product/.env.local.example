# Copy to .env.local for local dashboard dev.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ADR-006 Phase 3 (optional): dedicated GTM Supabase project for Founder OS + lead forms.
# When set, getSupabaseCrm()/getSupabaseGtm() use this project instead of the product URL above.
# Tenant crm_contacts stays on the product DB (NestJS backend only).
# SUPABASE_GTM_URL=https://your-gtm-project.supabase.co
# SUPABASE_GTM_SERVICE_ROLE_KEY=your-gtm-service-role-key

# Local Nest API (must match tracebud-backend `npm run start:dev` on port 4000).
TRACEBUD_BACKEND_URL=http://localhost:4000/api

# Use production API only when intentionally testing against deployed backend:
# TRACEBUD_BACKEND_URL=https://api.tracebud.com/api

NEXT_PUBLIC_FEATURE_REQUEST_CAMPAIGNS=true
TRACEBUD_DEV_SIGNUP_BYPASS=false

# Optional: high-res plot satellite maps (MapTiler) for all tenants when set.
# Get a key at https://cloud.maptiler.com/
# NEXT_PUBLIC_MAPTILER_API_KEY=your_maptiler_key
