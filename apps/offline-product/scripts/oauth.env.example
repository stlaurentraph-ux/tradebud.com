# Copy to oauth.env (gitignored) and run:
#   set -a && source scripts/oauth.env && set +a && npm run oauth:supabase:configure
#
# Supabase personal access token: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=uzsktajlnofosxeqwdwl
SUPABASE_SITE_URL=https://dashboard.tracebud.com
SUPABASE_REDIRECT_URLS=tracebudoffline://auth/callback

# Google Cloud → Credentials → OAuth 2.0 Web client
# Authorized redirect URI: https://uzsktajlnofosxeqwdwl.supabase.co/auth/v1/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Apple Developer → Services ID (Client ID for Supabase) + bundle ID for native iOS sign-in
# Supabase → Apple → Client IDs: com.tracebud.auth,com.tracebud.app
# Supabase → Apple → enable "Skip nonce check" for native iOS (expo-apple-authentication)
# Apple Developer → App ID com.tracebud.app → Sign in with Apple capability ON
APPLE_SERVICES_ID=
APPLE_BUNDLE_ID=com.tracebud.app

# Option A: paste generated JWT (expires ~every 6 months)
# APPLE_OAUTH_SECRET=

# Option B: generate JWT from .p8 key (used by configure script if APPLE_OAUTH_SECRET unset)
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=
