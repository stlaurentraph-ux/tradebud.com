# Copy to `.env` in this folder and restart Expo (`npx expo start -c`).
# Tracebud Nest API (see tracebud-backend): default port 4000 → base path includes /api

EXPO_PUBLIC_API_URL=http://localhost:4000/api

# On a physical device, use your computer's LAN IP (same Wi‑Fi), e.g.:
# EXPO_PUBLIC_API_URL=http://192.168.1.10:4000/api

# Production / EAS preview+production builds (set in Expo dashboard → Environment variables):
# EXPO_PUBLIC_API_URL=https://api.tracebud.com/api
# EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Never enable these in store builds:
# EXPO_PUBLIC_ALLOW_TEST_AUTH=1
# EXPO_PUBLIC_ALLOW_LOCALHOST_API=1
# EXPO_PUBLIC_ALLOW_INSECURE_API=1
