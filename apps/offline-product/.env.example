# Copy to `.env` in this folder and restart Expo (`npx expo start -c`).
# Tracebud Nest API (see tracebud-backend): default port 4000 → base path includes /api

EXPO_PUBLIC_API_URL=http://localhost:4000/api

# On a physical device, use your computer's LAN IP (same Wi‑Fi), e.g.:
# EXPO_PUBLIC_API_URL=http://192.168.1.10:4000/api

# Required for Android field maps (Walk perimeter, trace on map). Enable "Maps SDK for Android"
# in Google Cloud, restrict the key to package com.tracebud.app, then rebuild the dev client:
#   npx expo prebuild --platform android --clean && npx expo run:android
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: XYZ satellite tile template ({z}/{x}/{y}) for field maps. Default is Esri World Imagery.
# EXPO_PUBLIC_FIELD_MAP_TILE_URL=https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Observability (Sentry project: tracebud / react-native)
# Create at https://sentry.io → Settings → Projects → Client Keys (DSN)
# Required for production builds (`npm run release:preflight:production`).
EXPO_PUBLIC_SENTRY_DSN=
# Set to 1 to report errors from local dev builds (default: off in __DEV__)
# EXPO_PUBLIC_SENTRY_ENABLED=1
# EXPO_PUBLIC_SENTRY_ENVIRONMENT=development
# EXPO_PUBLIC_SENTRY_DEBUG=1

# Field-app auth host (defaults to https://app.tracebud.com). For local field-auth dev:
# EXPO_PUBLIC_OAUTH_BRIDGE_URL=http://localhost:3003/auth/callback
# EXPO_PUBLIC_FIELD_AUTH_CONFIRM_URL=http://localhost:3003/auth/confirm
# Dev client only — skip universal links and use tracebudoffline:// directly:
# EXPO_PUBLIC_OAUTH_USE_CUSTOM_SCHEME=1
# (Not required for `expo run:ios` — __DEV__ builds use the custom scheme automatically.)

# Native Google sign-in (shows "Tracebud" — not *.supabase.co).
# Web client: HTTPS redirect only → https://<project-ref>.supabase.co/auth/v1/callback
# Do NOT add tracebudoffline:// to the Web client (Google rejects custom schemes there).
# Create separate iOS + Android OAuth clients in Google Cloud (same project).
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=

# Build-time only — do not commit real tokens. EAS production has SENTRY_AUTH_TOKEN as a secret.
# Local: npm run sentry:token:local  (writes local/sentry-auth.env, gitignored)
# SENTRY_ORG=tracebud
# SENTRY_PROJECT=react-native
# SENTRY_AUTH_TOKEN=your_org_auth_token

# Tenant isolation API smoke (local only — see product-os/04-quality/golden-field-tenant-smoke.md)
# FIELD_TENANT_SMOKE_FARMER_A_EMAIL=field+tenant-smoke-a@tracebud.com
# FIELD_TENANT_SMOKE_FARMER_A_PASSWORD=
# FIELD_TENANT_SMOKE_FARMER_B_ID=
# FIELD_TENANT_SMOKE_FARMER_B_PLOT_ID=
# FIELD_TENANT_SMOKE_API_URL=https://api.tracebud.com/api

# Never set these for production store builds (release preflight will fail):
# EXPO_PUBLIC_ALLOW_TEST_AUTH=1
# EXPO_PUBLIC_TRACEBUD_TEST_EMAIL=
# EXPO_PUBLIC_TRACEBUD_TEST_PASSWORD=
