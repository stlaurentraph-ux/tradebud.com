# Copy to `.env` in this folder and restart Expo (`npx expo start -c`).
# Tracebud Nest API (see tracebud-backend): default port 4000 → base path includes /api

EXPO_PUBLIC_API_URL=http://localhost:4000/api

# On a physical device, use your computer's LAN IP (same Wi‑Fi), e.g.:
# EXPO_PUBLIC_API_URL=http://192.168.1.10:4000/api

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
