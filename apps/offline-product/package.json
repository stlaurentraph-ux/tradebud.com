{
  "name": "tracebud-offline",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "i18n:queue:smoke": "node ./scripts/i18n-queue-panel.smoke.mjs",
    "i18n:queue:summary:assert": "node ./scripts/i18n-queue-summary-assert.mjs",
    "i18n:queue:baseline:schema:assert": "node ./scripts/i18n-queue-baseline-schema-assert.mjs",
    "i18n:queue:report:generate": "node ./scripts/i18n-queue-report-generate.mjs",
    "i18n:queue:report:assert": "node ./scripts/i18n-queue-report-assert.mjs",
    "i18n:queue:verify": "node ./scripts/i18n-queue-verify.mjs",
    "i18n:queue:clean": "node ./scripts/i18n-queue-verify-clean.mjs",
    "i18n:queue:clean:all": "node ./scripts/i18n-queue-verify-clean.mjs --all",
    "i18n:queue:verify:clean": "npm run i18n:queue:verify && npm run i18n:queue:clean",
    "i18n:queue:verify:clean:all": "npm run i18n:queue:verify && npm run i18n:queue:clean:all",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "dev:ios": "expo run:ios",
    "dev": "node ./scripts/dev-phone-preflight.mjs",
    "dev:device": "bash ./scripts/run-ios-device-lan.sh",
    "dev:device:wait": "bash ./scripts/wait-and-install-ios-device.sh",
    "dev:device:ipad": "TRACE_BUD_IOS_DEVICE_KIND=ipad bash ./scripts/wait-and-install-ios-device.sh",
    "dev:android": "expo run:android",
    "dev:metro": "bash ./scripts/start-metro-lan.sh",
    "check:metro-start": "node ./scripts/validate-metro-start.mjs",
    "dev:metro:production": "TRACEBUD_SKIP_LAN_API_SYNC=1 EXPO_PUBLIC_API_URL=https://api.tracebud.com/api bash ./scripts/start-metro-lan.sh --clear",
    "dev:oauth:verify": "node ./scripts/verify-local-oauth-dev.mjs",
    "dev:oauth:ios": "EXPO_PUBLIC_API_URL=https://api.tracebud.com/api expo run:ios",
    "dev:oauth:device": "EXPO_PUBLIC_API_URL=https://api.tracebud.com/api bash ./scripts/run-ios-device-lan.sh",
    "web": "expo start --web",
    "lint": "expo lint --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "qa:preflight": "node ./scripts/device-qa-preflight.mjs",
    "qa:maestro:preflight": "node ./scripts/maestro-ci-preflight.mjs",
    "qa:maestro:write-baseline": "node ./scripts/maestro-ci-preflight.mjs --write-baseline",
    "qa:maestro:golden-path": "bash ./scripts/maestro-ci-golden-path.sh",
    "qa:maestro:nightly": "bash ./scripts/maestro-ci-nightly-smoke.sh",
    "qa:maestro:nightly:assert": "node ./scripts/maestro-nightly-smoke-guard.mjs",
    "security:preflight": "node ./scripts/security-preflight.mjs",
    "qa:full": "npm run lint && npm run typecheck && npm run security:preflight && npm run i18n:en:placeholder:assert && npm run test && npm run i18n:queue:smoke && npm run qa:preflight",
    "qa:regression": "npm run lint && npm run typecheck && npm run test && node ./scripts/field-regression-guard.mjs",
    "qa:automation:phase1": "node ./scripts/run-automation-guards.mjs",
    "qa:automation:phase1:strict": "node ./scripts/run-automation-guards.mjs --strict",
    "qa:automation:write-baselines": "node ./scripts/run-automation-guards.mjs --write-baseline",
    "openapi:codegen": "node ./scripts/generate-openapi-client-types.mjs",
    "openapi:codegen:assert": "node ./scripts/mobile-openapi-codegen-guard.mjs",
    "qa:device": "node ./scripts/device-qa-smoke.mjs",
    "qa:sync-connectivity": "node ./scripts/sync-connectivity-check.mjs",
    "qa:plot-restore-smoke": "node ./scripts/plot-restore-smoke.mjs",
    "qa:device:signoff": "node ./scripts/device-smoke-signoff.mjs",
    "qa:device:assert": "node ./scripts/device-smoke-signoff-assert.mjs",
    "test:maestro": "bash ./scripts/maestro-test.sh",
    "test:maestro:sync": "bash ./scripts/maestro-test.sh settings-sync-smoke.yaml",
    "test:maestro:seed": "node ./scripts/seed-maestro-simulator.mjs",
    "qa:tenant-isolation": "node ./scripts/field-tenant-isolation-smoke.mjs",
    "qa:tenant-isolation:assert": "node ./scripts/field-tenant-isolation-guard.mjs",
    "store:preflight": "node ./scripts/store-ops-preflight.mjs",
    "generate:app-icons": "python3 ./scripts/generate-app-icons.py",
    "store:assets:sync": "python3 ./scripts/sync-google-play-assets.py",
    "credentials:setup": "bash ./scripts/setup-eas-credentials.sh",
    "generate:store-screenshots": "python3 ./scripts/generate-app-store-screenshots.py",
    "store:screenshots:capture": "bash ./scripts/run-store-screenshot-capture.sh",
    "i18n:en:placeholder:assert": "node ./scripts/i18n-en-placeholder-assert.mjs",
    "release:preflight:preview": "node ./scripts/release-preflight.mjs --profile=preview",
    "release:preflight:production": "node ./scripts/release-preflight.mjs --profile=production",
    "release:preflight:production:online": "node ./scripts/release-preflight.mjs --profile=production --verify-oauth",
    "release:slo:gate": "node ./scripts/release-rollout-slo-gate.mjs",
    "mobile:slo:collect": "node ./scripts/mobile-rollout-slo-collect.mjs",
    "mobile:slo:gate": "node ./scripts/release-rollout-slo-gate.mjs",
    "mobile:slo:assert": "node ./scripts/mobile-rollout-slo-guard.mjs",
    "ota:skew:assert": "node ./scripts/eas-ota-skew-guard.mjs",
    "ota:production:preflight": "node ./scripts/ota-production-preflight.mjs",
    "ota:production:assert": "node ./scripts/ota-production-gate-guard.mjs",
    "release:preview": "npx eas-cli build --platform ios --profile preview",
    "release:preview:android": "npx eas-cli build --platform android --profile preview",
    "release:production": "npx eas-cli build --platform all --profile production",
    "release:preview:safe": "npm run qa:full && npm run release:preflight:preview && npm run release:preview",
    "release:production:safe": "npm run qa:full && npm run store:assets:sync && npm run store:preflight -- --strict && npm run release:preflight:production && npm run release:production",
    "submit:production": "npx eas-cli submit --platform all --profile production",
    "update:preview": "npm run update:preview:ios",
    "update:preview:all": "npm run update:preview:ios && npm run update:preview:android",
    "update:preview:safe": "npm run test && node ./scripts/field-regression-guard.mjs && node ./scripts/device-smoke-signoff-assert.mjs && npm run update:preview",
    "update:preview:ios": "CI=1 npx eas-cli update --branch preview --environment preview -p ios --message \"preview ota\" --non-interactive",
    "update:preview:android": "CI=1 npx eas-cli update --branch preview --environment preview -p android --message \"preview ota\" --non-interactive",
    "update:production": "npm run update:production:ios && npm run update:production:android",
    "update:production:safe": "npm run ota:production:preflight && npm run update:production",
    "update:production:ios": "CI=1 npx eas-cli update --branch production -p ios --message \"production ota\" --non-interactive",
    "update:production:android": "CI=1 npx eas-cli update --branch production -p android --message \"production ota\" --non-interactive",
    "ios:simulator": "bash ./scripts/setup-ios-simulator.sh",
    "build:simulator": "bash ./scripts/build-ios-simulator.sh",
    "run:simulator": "bash ./scripts/run-ios-simulator.sh",
    "open:simulator": "bash ./scripts/open-tracebud-simulator.sh",
    "capture:screenshot": "bash ./scripts/capture-simulator-screenshot.sh",
    "capture:ipad-screenshots": "bash ./scripts/capture-ipad-store-screenshots.sh",
    "oauth:verify": "node ./scripts/verify-oauth-providers.mjs",
    "oauth:sync-google-ids": "node ./scripts/sync-supabase-google-client-ids.mjs",
    "oauth:redirects:merge": "node ./scripts/merge-supabase-redirect-urls.mjs",
    "oauth:supabase:configure": "node ./scripts/configure-supabase-oauth.mjs",
    "sentry:token:local": "node ./scripts/set-sentry-auth-token-local.mjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "^2.99.1",
    "base64-js": "^1.5.1",
    "expo": "~54.0.35",
    "expo-apple-authentication": "~8.0.8",
    "expo-asset": "~12.0.13",
    "expo-auth-session": "~7.0.11",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~56.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-text-extractor": "^2.0.0",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "expo-module-scripts": "~4.1.10",
    "openapi-typescript": "^7.8.0",
    "typescript": "~5.9.2",
    "vitest": "^3.2.6"
  },
  "private": true
}
