{
  "schemaVersion": 1,
  "slice": "H25",
  "flowsBaseline": "qa/automation-baselines/maestro-flows.json",
  "goldenPathFlow": "settings-sync-smoke.yaml",
  "goldenPathFlowAndroid": "settings-sync-smoke-android.yaml",
  "goldenPathFlowAndroidSmoke": "android-pr-smoke.yaml",
  "workflowFile": ".github/workflows/offline-maestro.yml",
  "iosJobName": "Maestro golden path (macOS)",
  "androidJobName": "Maestro golden path (Android)",
  "androidSmokeJobName": "Maestro Android smoke (PR)",
  "androidAssembleJobName": "Maestro Android APK assemble",
  "ciTriggers": ["pull_request", "push"],
  "iosTimeoutMinutes": 120,
  "maestroSeedSkip": true,
  "goldenPathBootProfile": "golden_path_minimal",
  "goldenPathBootStateBaseline": "qa/automation-baselines/maestro-boot-state.json",
  "goldenPathBootWaitMs": 2700000,
  "bootDbWaitMs": 180000,
  "androidAssembleJobTimeoutMinutes": 45,
  "androidAssembleRunner": "ubuntu-latest",
  "androidJobTimeoutMinutes": 75,
  "androidSmokeJobTimeoutMinutes": 40,
  "androidSmokeBootWaitMs": 1800000,
  "androidSmokeSkipBootstrapWarm": true,
  "androidSmokeJsBootFailFastMs": 600000,
  "androidBootstrapWarmMs": 1200000,
  "androidJsBootFailFastMs": 1800000,
  "androidEmulatorSnapshotName": "maestro_ci_boot",
  "androidApkAssemblyScript": "scripts/maestro-ci-assemble-android-apk.sh",
  "iosSimulatorAssemblyScript": "scripts/maestro-ci-assemble-ios-simulator.sh",
  "androidEmulator": {
    "apiLevel": 33,
    "profile": "pixel_6",
    "driverStartupTimeoutMs": 300000,
    "emulatorArch": "x86_64",
    "emulatorRunner": "macos-15-intel",
    "emulatorOptions": "-no-window -gpu swiftshader_indirect -noaudio -no-boot-anim -memory 4096"
  },
  "costGate": {
    "platformGateScript": "scripts/maestro-ci-platform-gate.mjs",
    "cancelInProgressConcurrency": true,
    "skipIosWhenPrGreenAndAndroidOnly": true,
    "skipAndroidWhenPrGreenAndIosOnly": true,
    "androidPrRunsSmokeOnly": true,
    "androidGoldenOnPushAndDispatch": true,
    "fullMatrixOnPushToMain": true
  },
  "e2eBypass": {
    "enabled": false,
    "reason": "Re-enabled after H13 APK staging + resolver fixes for Android golden path",
    "allowedUntil": "2026-07-31",
    "keepPreflight": true,
    "reEnableRunbook": "Set e2eBypass.enabled to false in this manifest after Maestro Android smoke is green on PR"
  },
  "e2eApproval": {
    "prLabel": "maestro:run",
    "githubEnvironment": "maestro-e2e",
    "approvalGateScript": "scripts/maestro-ci-approval-gate.mjs",
    "runbookSection": "E2E approval gate (human opt-in)"
  },
  "prepushScript": "scripts/maestro-prepush.sh",
  "prepushRunbook": "product-os/04-quality/maestro-ci-cost-runbook.md"
}
