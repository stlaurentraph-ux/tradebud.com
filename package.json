{
  "name": "tracebud",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/dashboard-product",
    "apps/founder-os",
    "apps/marketing",
    "apps/field-auth",
    "tracebud-backend",
    "packages/tsconfig",
    "packages/eslint-config"
  ],
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "dev:backend": "npm run start:dev -w tracebud-backend",
    "dev:dashboard": "npm run dev -w dashboard-product",
    "dev:marketing": "npm run dev -w tracebud-marketing",
    "dev:offline": "npm run dev:metro --prefix apps/offline-product",
    "dev:field-auth": "npm run dev -w field-auth",
    "lint:backend": "npm run lint -w tracebud-backend",
    "lint:dashboard": "npm run lint -w dashboard-product",
    "lint:marketing": "npm run lint -w tracebud-marketing",
    "lint:offline": "npm run lint --prefix apps/offline-product",
    "lint:field-auth": "npm run lint -w field-auth",
    "lint:workspaces": "turbo run lint --filter=tracebud-backend --filter=dashboard-product --filter=tracebud-marketing --filter=./apps/offline-product",
    "test:workspaces": "turbo run test --filter=./apps/offline-product --filter=field-auth",
    "build:workspaces": "turbo run build --filter=tracebud-backend --filter=dashboard-product --filter=founder-os --filter=tracebud-marketing --filter=field-auth",
    "typecheck:workspaces": "turbo run typecheck --filter=./apps/offline-product --filter=dashboard-product --filter=founder-os --filter=tracebud-marketing --filter=field-auth",
    "typecheck:dashboard": "npm run typecheck -w dashboard-product",
    "typecheck:marketing": "npm run typecheck -w tracebud-marketing",
    "build:dashboard": "npm run build -w dashboard-product",
    "check:dashboard": "npm run lint:dashboard && npm run typecheck:dashboard && npm test -w dashboard-product && npm run regression:routes:assert -w dashboard-product && npm run build:dashboard",
    "check:marketing": "npm run lint:marketing && npm run typecheck:marketing && npm run i18n:parity:assert -w tracebud-marketing && npm run routes:publication:assert -w tracebud-marketing && npm run build:marketing && npm run api:trace:size:assert -w tracebud-marketing",
    "turbo:cache:report": "node scripts/turbo-remote-cache-guard.mjs",
    "sentry:env:assert": "node scripts/sentry-env-tags-guard.mjs",
    "qa:structural:monorepo": "node scripts/run-monorepo-structural-guards.mjs",
    "qa:structural:monorepo:ci": "node scripts/run-monorepo-structural-guards.mjs --ci",
    "smoke:marketing:post-deploy": "npm run smoke:post-deploy -w tracebud-marketing",
    "uptime:probes:manifest:assert": "node scripts/uptime-probes-manifest-guard.mjs",
    "uptime:probes:run": "node scripts/uptime-probes-run.mjs",
    "pr:labeler:assert": "node scripts/pr-labeler-guard.mjs",
    "n8n:workflow-b:assert": "node scripts/n8n-workflow-b-guard.mjs",
    "n8n:workflow-f:assert": "node scripts/n8n-workflow-f-guard.mjs",
    "golden:staging:assert": "node scripts/golden-staging-tenant-guard.mjs",
    "release:health:assert": "node scripts/release-health-gate-guard.mjs",
    "release:health:gate": "node scripts/release-health-gate.mjs",
    "release:health:collect": "node scripts/release-health-collect.mjs",
    "weekly:health:assert": "node scripts/weekly-health-automation-guard.mjs",
    "check:workspaces": "npm run lint:workspaces && npm run test:workspaces && npm run typecheck:workspaces",
    "test:backend": "npm test -w tracebud-backend",
    "test:dashboard": "npm test -w dashboard-product",
    "test:offline": "npm run test --prefix apps/offline-product",
    "test:field-auth": "npm test -w field-auth",
    "build:marketing": "npm run build -w tracebud-marketing",
    "build:backend": "npm run build -w tracebud-backend",
    "i18n:queue:smoke": "npm run i18n:queue:smoke --prefix apps/offline-product",
    "i18n:queue:verify": "npm run i18n:queue:verify --prefix apps/offline-product",
    "i18n:queue:verify:clean": "npm run i18n:queue:verify:clean --prefix apps/offline-product",
    "i18n:queue:verify:clean:all": "npm run i18n:queue:verify:clean:all --prefix apps/offline-product",
    "openapi:lint": "npx @redocly/cli lint --config .redocly.yaml docs/openapi/tracebud-v1-draft.yaml",
    "supabase:migration:naming:assert": "node scripts/supabase-migration-naming-guard.mjs",
    "supabase:migration:mirror:assert": "node scripts/supabase-migration-mirror-drift-guard.mjs",
    "supabase:migration:mirror:baseline:refresh": "node scripts/supabase-migration-mirror-drift-guard.mjs --write-baseline",
    "openapi:baseline:refresh": "node scripts/openapi-refresh-lint-baseline.mjs",
    "openapi:governance:markdown:check": "node scripts/openapi-governance/markdown-reference-check.mjs",
    "openapi:governance:readme:check": "node scripts/openapi-governance/readme-commands-check.mjs",
    "openapi:governance:policy:validate": "node scripts/openapi-governance/policy-validate.mjs",
    "openapi:governance:check": "node scripts/openapi-governance/codeowners-check.mjs",
    "openapi:governance:evidence-doc:parity:check": "node scripts/openapi-governance/evidence-doc-contract-parity-check.mjs",
    "openapi:governance:evidence-doc:parity:smoke": "node scripts/openapi-governance/evidence-doc-contract-parity.smoke.mjs",
    "openapi:governance:evidence-doc:parity:report:assert": "node scripts/openapi-governance/evidence-doc-parity-report-assert.mjs",
    "openapi:governance:evidence-doc:parity:metrics:generate": "node scripts/openapi-governance/evidence-doc-parity-metrics-generate.mjs",
    "openapi:governance:metrics:generate": "node scripts/openapi-governance/metrics-generate.mjs",
    "openapi:governance:metrics:smoke": "node scripts/openapi-governance/metrics-generate.smoke.mjs",
    "openapi:governance:metrics:trend": "node scripts/openapi-governance/metrics-trend-summary.mjs",
    "openapi:governance:metrics:trend:delta": "node scripts/openapi-governance/metrics-trend-delta.mjs",
    "openapi:governance:metrics:trend:report:assert": "node scripts/openapi-governance/trend-report-assert.mjs",
    "openapi:governance:metrics:trend:delta:report:assert": "node scripts/openapi-governance/trend-delta-report-assert.mjs",
    "openapi:governance:metrics:trend:assertions:smoke": "node scripts/openapi-governance/trend-assertions.smoke.mjs",
    "openapi:governance:metrics:presentation:check": "node scripts/openapi-governance/metrics-presentation-check.mjs",
    "openapi:governance:readme:report:assert": "node scripts/openapi-governance/readme-report-assert.mjs",
    "openapi:governance:assessment:aliases:check": "node scripts/openapi-governance/assessment-route-alias-check.mjs",
    "openapi:governance:markdown:report:assert": "node scripts/openapi-governance/markdown-report-assert.mjs",
    "openapi:governance:artifacts:assert": "node scripts/openapi-governance/artifacts-assert.mjs",
    "openapi:governance:snapshot:registry:check": "node scripts/openapi-governance/snapshot-registry-check.mjs",
    "openapi:governance:snapshot:registry:report:assert": "node scripts/openapi-governance/snapshot-registry-report-assert.mjs",
    "prepare": "husky",
    "lint:staged": "lint-staged",
    "dev:founder-os": "npm run dev -w founder-os",
    "lint:founder-os": "npm run lint -w founder-os",
    "check:founder-os": "npm run lint:founder-os && npm run typecheck -w founder-os && npm run build -w founder-os"
  },
  "dependencies": {
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "turbo": "^2.5.4",
    "typescript": "5.7.3"
  },
  "overrides": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3"
  }
}
