{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tracebud.com/schemas/openapi-governance-codeowners-policy.schema.json",
  "title": "OpenAPI Governance CODEOWNERS Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["requiredEntries"],
  "properties": {
    "description": {
      "type": "string",
      "minLength": 1
    },
    "requiredEntries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "owners"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "owners": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^@[^\\s]+$"
            }
          }
        }
      }
    }
  }
}
