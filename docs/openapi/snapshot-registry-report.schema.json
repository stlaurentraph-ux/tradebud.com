{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tracebud.com/schemas/snapshot-registry-report.schema.json",
  "title": "Snapshot Registry Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "markdownPath",
    "rowCount",
    "status",
    "errors"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "markdownPath": {
      "type": "string",
      "minLength": 1
    },
    "rowCount": {
      "type": "integer",
      "minimum": 0
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "FAIL"]
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
