{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tracebud.com/schemas/markdown-reference-report.schema.json",
  "title": "Markdown Reference Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "markdownPath",
    "packageJsonPath",
    "enforceCommands",
    "enforcePaths",
    "commandCount",
    "pathCount",
    "missingCommands",
    "missingPaths",
    "status",
    "errors"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "markdownPath": {
      "type": "string",
      "minLength": 1
    },
    "packageJsonPath": {
      "type": "string",
      "minLength": 1
    },
    "enforceCommands": {
      "type": "boolean"
    },
    "enforcePaths": {
      "type": "boolean"
    },
    "commandCount": {
      "type": "integer",
      "minimum": 0
    },
    "pathCount": {
      "type": "integer",
      "minimum": 0
    },
    "missingCommands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missingPaths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "FAIL"]
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
